## Front (Vite)
VITE_API_BASE_URL=https://api.sobreapp.online
VITE_META_PIXEL_ID=

# Sandbox fallback userId for explicitly isolated local tests only.
# This fallback is used only when the funnel URL contains ?sandbox=1.
VITE_SANDBOX_USER_ID=sbx_user_123

# Stripe publishable key (public)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal (public client id) + plan ids for each offer
VITE_PAYPAL_CLIENT_ID=...
VITE_PAYPAL_PLAN_MONTH_50=P-...
VITE_PAYPAL_PLAN_MONTH_60=P-...
VITE_PAYPAL_PLAN_YEAR_50=P-...
VITE_PAYPAL_PLAN_YEAR_60=P-...
