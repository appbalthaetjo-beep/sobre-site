## Server (Stripe)
PORT=4242

# Front origin for CORS + redirect URLs
CLIENT_URL=http://localhost:5173

# Supabase admin config used to resolve or create the Auth user before Stripe checkout
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

## Stripe
STRIPE_SECRET_KEY=sk_test_...

# Stripe Prices (mode=subscription) for each offer
PRICE_MONTH_50=price_...
PRICE_MONTH_60=price_...
PRICE_YEAR_50=price_...
PRICE_YEAR_60=price_...

# HMAC signature secret for funnel userId links
USER_ID_SIGNATURE_SECRET=replace_with_long_random_secret

# Link signature TTL in seconds (default 1800 = 30 min)
USER_ID_SIGNATURE_MAX_AGE_SECONDS=1800

# Server-to-server API key required to generate signed funnel URLs
FUNNEL_SIGNER_API_KEY=replace_with_random_api_key

# Optional: public funnel base URL if different from CLIENT_URL
FUNNEL_BASE_URL=https://your-funnel-domain.com

# Explicit sandbox override for isolated local tests only.
# Leave disabled for real Stripe / RevenueCat attachment tests.
SANDBOX_DEFAULT_USER_ID=sbx_user_123
ALLOW_SANDBOX_CHECKOUT=false
